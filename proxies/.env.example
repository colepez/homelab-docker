# Cloudflare Tunnel token (Zero Trust dashboard -> Tunnels -> your tunnel -> Install connector)
CLOUDFLARE_TUNNEL_TOKEN=

# Timezone for container clocks/logs
TZ=

# Cloudflare API token scoped to Zone:DNS:Edit, restricted to the ACME_DOMAIN zone only
CF_TOKEN=

# Domain to issue the wildcard cert for via DNS-01 (e.g. example.com)
ACME_DOMAIN=

# Host path to a BlueMap web-render output directory, mounted read-only for
# nginx to serve as a live map (see the corresponding minecraft stack's
# BlueMap config for the render's actual output path)
BLUEMAP_ATM10_WEB_PATH=
BLUEMAP_ZINNBERLYCRAFT_WEB_PATH=
