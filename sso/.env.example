# Postgres password for Keycloak's database (shared between keycloak-db and keycloak)
KEYCLOAK_DB_PASSWORD=

# Keycloak initial admin account (bootstrap only - creates the account on first
# start if it doesn't already exist; safe to leave set after that)
KEYCLOAK_ADMIN_USERNAME=
KEYCLOAK_ADMIN_PASSWORD=

# Hostname Keycloak issues tokens/SAML assertions for - must match the nginx
# vhost that proxies to it (e.g. sso.example.com)
SSO_HOSTNAME=
