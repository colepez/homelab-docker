# Timezone for container clocks/logs
TZ=

# Slack incoming webhook URL Diun posts new-image-available notifications to
# (Slack -> Apps -> Incoming Webhooks -> Add to Slack)
# Swap for a different Diun notif provider (Discord, Gotify, ntfy, etc.) if preferred.
DIUN_NOTIF_SLACK_WEBHOOKURL=

# Grafana admin login password (Grafana -> Administration -> Users -> admin,
# or set here before first boot to skip the default admin/admin login)
GRAFANA_ADMIN_PASSWORD=
