# Timezone for container clocks/logs
TZ=

# Slack incoming webhook URL Diun posts new-image-available notifications to
# (Slack -> Apps -> Incoming Webhooks -> Add to Slack). Optional - leave blank
# if only using Discord below.
DIUN_NOTIF_SLACK_WEBHOOKURL=

# Discord webhook URL Diun posts new-image-available notifications to
# (Discord -> Server Settings -> Integrations -> Webhooks -> New Webhook ->
# copy URL). Format: https://discord.com/api/webhooks/<id>/<token>
DIUN_NOTIF_DISCORD_WEBHOOKURL=
