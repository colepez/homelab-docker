# Timezone for container clocks/logs and scheduling
TZ=

# UID/GID all containers run as - must match whatever the /mnt/media NFS
# export from TrueNAS is mapped to, so containers can actually read/write it
PUID=1000
PGID=1000

# Mullvad WireGuard key, generated at mullvad.net/en/account -> WireGuard
# config generator. WIREGUARD_ADDRESSES is the IP address it assigns you
# there alongside the key (not your home/LAN IP).
MULLVAD_WIREGUARD_PRIVATE_KEY=
MULLVAD_WIREGUARD_ADDRESSES=

# Optional: comma-separated Mullvad city codes to restrict which VPN servers
# gluetun picks (e.g. "Los Angeles CA,Dallas TX"). Leave blank for any.
MULLVAD_SERVER_CITIES=

# Transmission's peer port. NOTE: since Transmission's traffic is tunneled
# through Mullvad, this is NOT a home-router port forward - it only works if
# port forwarding is separately enabled on the Mullvad account/server side.
# Without that, downloads still work but connect to fewer peers.
TRANSMISSION_PEER_PORT=51413

# One-time claim token from https://plex.tv/claim - valid for 4 minutes, so
# grab it right before deploying/redeploying this stack for the first time
PLEX_CLAIM=
