# Timezone for container clocks/logs
TZ=

# Comma-separated hostnames/IPs homepage will accept in the Host header
# e.g. 10.21.2.62,dashboard.example.com
ALLOWED_HOSTS=

# TrueNAS API key (TrueNAS UI -> Settings -> API Keys -> Add), used by the
# TrueNAS storage widget on the dashboard
HOMEPAGE_VAR_TRUENAS_KEY=

# Proxmox API token (Proxmox UI -> Datacenter -> Permissions -> API Tokens -> Add)
# used by the Proxmox widget on the dashboard.
# HOMEPAGE_VAR_PROXMOX_TOKEN_ID is the "user@realm!tokenid" part (e.g. homepage@pve!dashboard)
# HOMEPAGE_VAR_PROXMOX_SECRET is the secret shown once when the token is created
HOMEPAGE_VAR_PROXMOX_TOKEN_ID=
HOMEPAGE_VAR_PROXMOX_SECRET=
